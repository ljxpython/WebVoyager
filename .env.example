# Copy this file to .env and fill in real values.
# Do not commit .env.

# OpenAI-compatible model endpoint for WebVoyager and CUA.
DOUBAO_API_KEY=
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_MODEL=doubao-seed-2-0-pro-260215

# Optional OpenAI-compatible aliases. If set, these can be used by WebVoyager.
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_BASE_URL=
OPENAI_API_MODEL=

# CUA black-box integration. The adapter only runs compiled CUA output.
CUA_NODE_BIN=node
CUA_CWD=/path/to/cua
CUA_BIN=/path/to/cua/dist/cli/bin.js
CUA_CONFIG_PATH=config/cua_eval.json
CUA_RAW_RUNS_DIR=results/cua_raw_runs
CUA_CONVERTED_DIR=results/cua_webvoyager
CUA_MAX_STEPS=15
CUA_MAX_IMAGES=3
CUA_PROVIDER=openai

# Evaluation profile label used in summaries. First version is not strict vision-only
# because CUA still has some system tools available unless separately constrained.
CUA_PROFILE=gui-biased

# Compatibility aliases are also supported if your local env already uses them:
# OSWORLD_CUA_REPO_ROOT=/path/to/cua
# OSWORLD_CUA_BIN=/path/to/cua/dist/cli/bin.js
